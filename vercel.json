{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "regions": ["gru1"],
  "git": {
    "deploymentEnabled": {
      "gh-pages": false
    }
  },
  "crons": [
    {
      "path": "/api/cora/cron-sync",
            "schedule": "0 0 * * *"
    },
    {
      "path": "/api/enrd/montagem/cron-sync",
      "schedule": "30 5 * * *"
    },
    {
      "path": "/api/live-shop/cron",
      "schedule": "0 3 * * *"
    }
  ]
}
