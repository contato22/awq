# Notion Integration — Caza Vision (import-only, never queried at runtime)
# Use NOTION_TOKEN (preferred) or NOTION_API_KEY (legacy alias)
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# Notion Database IDs — Caza Vision (confirmed IDs, hardcoded as fallbacks in fetch script)
NOTION_DATABASE_ID_CAZA_PROPERTIES=308e2d13-dfa9-433e-a0f6-8439b5181845
NOTION_DATABASE_ID_CAZA_FINANCIAL=9a8329e9-6d19-4bdc-8e80-2d59a2658be7
NOTION_DATABASE_ID_CAZA_CLIENTS=ca1ba0fe-3d47-4356-8643-23a223a4e710

# Anthropic (OpenClaw AI assistant)
ANTHROPIC_API_KEY=sk-ant-...

# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://your-vercel-domain.vercel.app

# Operational URL — shown in /awq/management governance hub
# On Vercel this is auto-set as VERCEL_URL (server-side only).
# The production URL is: https://awq-brown.vercel.app
# Set NEXT_PUBLIC_APP_URL if you want the canonical alias shown in management.
NEXT_PUBLIC_APP_URL=https://awq-brown.vercel.app

# ── Vercel / Neon infra (production) ─────────────────────────────────────────
# Neon Postgres — documents and transactions persistence
# Leave unset for local dev (falls back to JSON files in public/data/financial/)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Vercel Blob — PDF storage across deployments
# Leave unset for local dev (falls back to local filesystem)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# ── Google Drive Storage — AWQ Group PDFs (opcional, substitui Vercel Blob) ───
#
# Prioridade: Google Drive > Vercel Blob > filesystem local
# Escopo: apenas pipeline de ingestão financeira AWQ (/awq/ingest)
# Conta: eqoa@ultrapack.cloud
#
# Estrutura criada no Drive:
#   AWQ Group — Storage/            (1yTmAlPIYTcDesDW8zpb9XbRpYqoIUXIN)
#   ├── PDFs Financeiros/           (1TrDrAdWOqTFKl6qP5jy-nTJspd3Vy3pj)  ← usar este
#   └── Extratos Bancários/         (1BJckrTnGgHk3-_Zq4O0E2nYc-VJzJZO9)
#
# PENDENTE: GOOGLE_SERVICE_ACCOUNT_KEY
#   O Drive está conectado via MCP (sessão Claude), mas o app Vercel
#   precisa de credenciais próprias para autenticar server-side.
#   Opção A: Google Cloud Console com conta pessoal Gmail → Service Account JSON
#   Opção B: Trocar para Cloudflare R2 (sem GCP — ver R2_* abaixo)
#
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"nome@projeto.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
GOOGLE_DRIVE_FOLDER_ID=1TrDrAdWOqTFKl6qP5jy-nTJspd3Vy3pj
