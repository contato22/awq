# Notion Integration — Caza Vision (import-only, never queried at runtime)
# Use NOTION_TOKEN (preferred) or NOTION_API_KEY (legacy alias)
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# Notion Database IDs — Caza Vision (confirmed IDs, hardcoded as fallbacks in fetch script)
NOTION_DATABASE_ID_CAZA_PROPERTIES=308e2d13-dfa9-433e-a0f6-8439b5181845
NOTION_DATABASE_ID_CAZA_FINANCIAL=9a8329e9-6d19-4bdc-8e80-2d59a2658be7
NOTION_DATABASE_ID_CAZA_CLIENTS=ca1ba0fe-3d47-4356-8643-23a223a4e710

# Anthropic (OpenClaw AI assistant)
ANTHROPIC_API_KEY=sk-ant-...

# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://your-vercel-domain.vercel.app

# Operational URL — shown in /awq/management governance hub
# On Vercel this is auto-set as VERCEL_URL (server-side only).
# The production URL is: https://awq-brown.vercel.app
# Set NEXT_PUBLIC_APP_URL if you want the canonical alias shown in management.
NEXT_PUBLIC_APP_URL=https://awq-brown.vercel.app

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL: https://<ref>.supabase.co
SUPABASE_URL=https://gqkgsoglgubmaborixfb.supabase.co

# Service role key — server-side only, bypasses RLS. Keep secret, never expose in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Anon / public key — safe to expose in browser (subject to RLS policies).
NEXT_PUBLIC_SUPABASE_URL=https://gqkgsoglgubmaborixfb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Direct Postgres connection — Supabase direct connection (port 5432).
# Get this from: Supabase dashboard → Settings → Database → Connection string → URI
# Leave unset for local dev (falls back to JSON files / seed data).
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.gqkgsoglgubmaborixfb.supabase.co:5432/postgres

# ── Vercel Blob — PDF storage across deployments ──────────────────────────────
# Leave unset for local dev (falls back to local filesystem)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# ── Cora Bank — Integração Direta ─────────────────────────────────────────────
# Gerado em: Cora app → Conta → Integrações via APIs (requer plano CoraPro)
# Docs: https://developers.cora.com.br/docs/instrucoes-iniciais
#
# CORA_ENV: "stage" para sandbox (credenciais de teste) | "production" para dados reais
CORA_ENV=production

# ── Conta PJ AWQ Holding ──────────────────────────────────────────────────────
CORA_CLIENT_ID=your-cora-client-id-here
# Cole o conteúdo do arquivo .pem do certificado (inclua header/footer e \n entre linhas)
CORA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# Cole o conteúdo da chave privada (inclua header/footer e \n entre linhas)
CORA_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ── Conta PJ JACQES (conta Cora separada) ────────────────────────────────────
# Se não configuradas, o sistema usa as credenciais da AWQ Holding como fallback.
CORA_JACQES_CLIENT_ID=your-cora-jacqes-client-id-here
CORA_JACQES_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
CORA_JACQES_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ── ENERDY Portal — app "Controle de Montagem" ───────────────────────────────
# scripts/fetch-enerdy-portal.mjs → public/data/enerdy-portal/
# Os dados de montagem ficam no app montagens.enerdy.com.br, que tem Supabase
# PRÓPRIO (gxgvucnkldzcktdzkkdv) — separado do hub de auth gestao.enerdy.com.br
# (atkkcjfylbeijwgctbse). Cada sub-app tem seu próprio pool de usuários.
# O email de login é derivado como `${ENERDY_USER}@enerdy.local` (regra do portal).
# Usado por scripts/fetch-enerdy-portal.mjs E por POST /api/enrd/montagem/sync
# (espelho do portal no banco da AWQ). A conta precisa de ACESSO DE LEITURA na
# RLS do app — uma conta admin do portal (role=admin) funciona.
ENERDY_BASE_URL=https://montagens.enerdy.com.br
# IMPORTANTE: credenciais válidas NO app de montagem (não as do hub).
ENERDY_USER=seu_usuario
ENERDY_PASS=sua-senha
ENERDY_SUPABASE_URL=https://gxgvucnkldzcktdzkkdv.supabase.co
# Anon key pública (subject to RLS) — embarcada no frontend; hardcoded como fallback.
ENERDY_SUPABASE_ANON_KEY=your-enerdy-anon-key
# Nome da tabela (default: installations; tenta candidatos montagem/montagens/...)
ENERDY_TABLE=installations

# ── ENERDY Pós-venda/O&M — app "projetos" (CRM de pós-venda) ──────────────────
# A OS real de pós-venda vive no app projetos.enerdy (gestão "Pós Venda"),
# backend PRÓPRIO gxgv≠ — zecancsoeyjnagxkrxnk, tabela pos_venda_servicos.
# IMPORTANTE: esse app usa email `${ENERDY_USER}@enerdy.com.br` (não @enerdy.local).
# Reusa ENERDY_USER/ENERDY_PASS (mesma conta felipe, role admin).
ENERDY_PROJETOS_URL=https://zecancsoeyjnagxkrxnk.supabase.co
# Anon key pública (embarcada no frontend; hardcoded como fallback no leitor).
ENERDY_PROJETOS_ANON_KEY=your-projetos-anon-key
# Domínio do email de login do app projetos (default: enerdy.com.br)
ENERDY_PROJETOS_EMAIL_DOMAIN=enerdy.com.br

# ── ERP — Supabase ────────────────────────────────────────────────────────────
# Public (browser-safe) — anon key, subject to RLS
NEXT_PUBLIC_ERP_SUPABASE_URL=https://kkhxxsrgsewjfvnnssyf.supabase.co
NEXT_PUBLIC_ERP_SUPABASE_ANON_KEY=your-erp-supabase-anon-key
# Server-only — service role key, bypasses RLS. Never expose to the browser.
ERP_SUPABASE_SERVICE_ROLE_KEY=your-erp-supabase-service-role-key

# ── Live Shop — TikTok Shop Open API (§14) ────────────────────────────────────
# Miguel registra o Custom app no TikTok Partner Center (business region = Brasil)
# e provê os segredos via Vercel env (server-side, NUNCA no repo/client).
# Scopes: order, product, inventory, logistics, finance, return. Versão fixada 202407.
TIKTOK_APP_KEY=
TIKTOK_APP_SECRET=
# CRON_SECRET já documentado acima — protege /api/live-shop/cron (Vercel Cron).
