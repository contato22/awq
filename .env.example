# Notion Integration — Caza Vision
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# Notion Database IDs (mesmo database — DATA BASE)
NOTION_DATABASE_ID_CAZA_FINANCIAL=2a58b3e6-fc37-80ce-bb78-c33f19ee1829
NOTION_DATABASE_ID_CAZA_PROPERTIES=2a58b3e6-fc37-80ce-bb78-c33f19ee1829
NOTION_DATABASE_ID_CAZA_CLIENTS=             # Clientes database ID (se existir)

# Anthropic (OpenClaw AI assistant)
ANTHROPIC_API_KEY=sk-ant-...

# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://your-vercel-domain.vercel.app

# Operational URL — shown in /awq/management governance hub
# On Vercel this is auto-set as VERCEL_URL (server-side only).
# Set this if you want the canonical URL shown in management even outside Vercel.
NEXT_PUBLIC_APP_URL=https://your-vercel-domain.vercel.app

# ── Vercel / Neon infra (production) ─────────────────────────────────────────
# Neon Postgres — documents and transactions persistence
# Leave unset for local dev (falls back to JSON files in public/data/financial/)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Vercel Blob — PDF storage across deployments
# Leave unset for local dev (falls back to local filesystem)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx
