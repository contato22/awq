# Notion Integration — Caza Vision (import-only, never queried at runtime)
# Use NOTION_TOKEN (preferred) or NOTION_API_KEY (legacy alias)
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# Notion Database IDs — Caza Vision (confirmed IDs, hardcoded as fallbacks in fetch script)
NOTION_DATABASE_ID_CAZA_PROPERTIES=308e2d13-dfa9-433e-a0f6-8439b5181845
NOTION_DATABASE_ID_CAZA_FINANCIAL=9a8329e9-6d19-4bdc-8e80-2d59a2658be7
NOTION_DATABASE_ID_CAZA_CLIENTS=ca1ba0fe-3d47-4356-8643-23a223a4e710

# Anthropic (OpenClaw AI assistant)
ANTHROPIC_API_KEY=sk-ant-...

# NextAuth
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://your-vercel-domain.vercel.app

# Operational URL — shown in /awq/management governance hub
# On Vercel this is auto-set as VERCEL_URL (server-side only).
# The production URL is: https://awq-brown.vercel.app
# Set NEXT_PUBLIC_APP_URL if you want the canonical alias shown in management.
NEXT_PUBLIC_APP_URL=https://awq-brown.vercel.app

# ── Supabase (production) ─────────────────────────────────────────────────────
# Dashboard → Settings → Database → Connection string → Transaction pooler
# Use the Transaction Pooler URL (port 6543) for Vercel serverless compatibility.
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase API — for client-side queries and auth (if used)
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Vercel Blob — PDF storage across deployments
# Leave unset for local dev (falls back to local filesystem)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx
